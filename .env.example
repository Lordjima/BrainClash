# Production Hostinger example
NODE_ENV=production
PORT=3000
APP_URL=https://brainclash.fr

# Twitch OAuth
TWITCH_CLIENT_ID=replace_me
TWITCH_CLIENT_SECRET=replace_me

# Database (MySQL recommended in production)
USE_MYSQL=true
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=replace_me
DB_PASSWORD=replace_me
DB_NAME=brainclash
