# App
NODE_ENV=production
PORT=3000
APP_URL=https://brainclash.fr

# Twitch OAuth
TWITCH_CLIENT_ID=your_twitch_client_id
TWITCH_CLIENT_SECRET=your_twitch_client_secret

# Database mode
# true = MySQL Hostinger / false = SQLite local fallback
USE_MYSQL=true

# MySQL Hostinger
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=brainclash
DB_CONNECTION_LIMIT=10

# SQLite fallback
SQLITE_FILE=./database.sqlite
